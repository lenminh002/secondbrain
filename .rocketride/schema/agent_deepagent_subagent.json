        },
        "ui:options": {
          "label": false,
          "nonNestedDisplay": true
        },
        "ui:order": [
          "description",
          "advanced_mode",
          "instructions",
          "system_prompt"
        ]
      },
      "ui:order": [
        "default"
      ]
    }
  },
  "plans": null,
  "prefix": "agent",
  "protocol": "agent_deepagent_subagent://",
  "title": "Deep Agent Subagent"
