{
  "actions": 0,
  "capabilities": 3072,
  "classType": [
    "deepagent"
  ],
  "description": "Managed Deep Agent subagent. Must be wired into a Deep Agent node via the deepagent channel.\nCannot be invoked directly — has no questions lane.",
