  "description": "A persistent cross-session memory node that retains data across pipeline\ninvocations. Supports Redis for production and in-memory backends for\ntesting. Provides session management, keyed storage, history tracking,\nand automatic summarization of older entries.",
  "icon": "memory.svg",
  "input": [
    {
      "description": "Questions are enriched with session memory context before forwarding",
      "lane": "questions",
      "output": [
        {
          "description": "Questions with memory context attached in metadata",
          "lane": "questions"
        }
      ]
    },
    {
      "description": "Answers are stored in session memory for future retrieval",
      "lane": "answers",
      "output": [
        {
          "description": "Answers passed through after persistence",
          "lane": "answers"
        }
      ]
    }
  ],
  "lanes": {
    "answers": [
      "answers"
    ],
    "questions": [
      "questions"
    ]
  },
  "Pipe": {
    "schema": {
      "properties": {
        "auto_summarize": {
          "default": true,
          "description": "Automatically summarize older history entries when limit is reached",
          "title": "Auto-Summarize",
          "type": "boolean"
        },
        "backend": {
          "default": "memory",
          "description": "Storage backend: redis (production) or memory (testing)",
