                      ]
                    },
                    "webhookUrl": {
                      "description": "Public HTTPS URL Telegram will POST updates to (e.g. https://your-server.com/telegram/webhook). Required for webhook mode.",
                      "title": "Webhook URL",
                      "type": "string"
                    }
                  }
                },
                {
                  "properties": {
