# =============================================================================
# Second-Brain backend environment template.
# Copy to .env and fill in your values:  cp .env.example .env
# .env is gitignored — never commit real secrets.
# IMPORTANT: keep comments on their OWN lines. python-dotenv does NOT strip
# trailing "# ..." comments here, so "KEY=value  # note" makes the value
# literally "value  # note".
# =============================================================================

# --- AI providers ------------------------------------------------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Optional: personal Claude OAuth token, used as a fallback when the API key is
# rate-limited (see ResilientAnthropic in knowledge_ai.py).
# CLAUDE_OAUTH_TOKEN=

# --- Agentic PDF processing (Knowledge Librarian Agent) ----------------------
# AGENT_ENABLED: enables the agentic PDF processing path.
AGENT_ENABLED=true
# AGENT_MAX_STEPS: max tool-use turns Claude may take per run.
AGENT_MAX_STEPS=12
# AGENT_PROCESSING_MODE: "agent" uses the controller; anything else = deterministic fallback.
AGENT_PROCESSING_MODE=agent
# AGENT_SAVE_TRACE: saves a short safe tool trace (never chain-of-thought).
AGENT_SAVE_TRACE=true

# --- Storage backend ---------------------------------------------------------
# "memory" = in-process seeded demo data (no credentials needed).
# "firestore" = persist to Cloud Firestore (requires Firebase credentials below).
SECONDBRAIN_STORAGE_BACKEND=memory
SECONDBRAIN_SEED_MOCK_DATA=1

# --- Firebase / Firestore credentials (used when backend=firestore) ----------
FIREBASE_PROJECT_ID=
# Path is resolved from the directory you run uvicorn in (the repo root).
FIREBASE_SERVICE_ACCOUNT_FILE=./firebase-service-account.json
# Or paste the whole JSON inline instead of a file:
# FIREBASE_SERVICE_ACCOUNT_JSON=
# Local persistence without a service account:
# FIRESTORE_EMULATOR_HOST=127.0.0.1:8080

# --- Original PDF storage provider -------------------------------------------
# Where uploaded PDFs are parked: "github" (default) or "drive".
ORIGINAL_FILE_STORAGE=github

# --- GitHub storage (used when ORIGINAL_FILE_STORAGE=github) ------------------
# A token with write access to a (public) repo, e.g. `gh auth token`.
GITHUB_TOKEN=
# owner/repo that receives the uploaded PDFs (public => links are world-readable).
GITHUB_STORAGE_REPO=
GITHUB_STORAGE_BRANCH=main
GITHUB_STORAGE_PATH_PREFIX=uploads

# --- Google Drive (used when ORIGINAL_FILE_STORAGE=drive) ---------------------
# Note: a service account on a personal My Drive hits "storageQuotaExceeded".
# It needs a Shared Drive (Workspace). GitHub storage avoids that entirely.
# 1. Create a Google Cloud service account + JSON key (see README / setup notes).
# 2. Create a Drive folder, copy its ID from the URL, and SHARE that folder
#    with the service account's client_email (Editor).
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_DRIVE_SERVICE_ACCOUNT_FILE=./google-drive-service-account.json
# Or inline JSON instead of a file:
# GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON=

# --- Frontend config ---------------------------------------------------------
# Vite reads these from frontend/.env.local, NOT this file. Listed for reference.
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_APP_ID=
