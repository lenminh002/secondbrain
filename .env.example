# =============================================================================
# Second-Brain backend environment template.
# Copy to .env and fill in your values:  cp .env.example .env
# .env is gitignored — never commit real secrets.
# =============================================================================

# --- AI providers ------------------------------------------------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Optional: personal Claude OAuth token used by local tooling (not the app/API).
# CLAUDE_OAUTH_TOKEN=

# --- Agentic PDF processing (Knowledge Librarian Agent) ----------------------
AGENT_ENABLED=true          # Enables the agentic PDF processing path.
AGENT_MAX_STEPS=12          # Max tool-use turns Claude may take per run.
AGENT_PROCESSING_MODE=agent # "agent" uses the controller; anything else = deterministic fallback.
AGENT_SAVE_TRACE=true       # Saves a short safe tool trace (never chain-of-thought).

# --- Storage backend ---------------------------------------------------------
# "memory" = in-process seeded demo data (no credentials needed).
# "firestore" = persist to Cloud Firestore (requires Firebase credentials below).
SECONDBRAIN_STORAGE_BACKEND=memory
SECONDBRAIN_SEED_MOCK_DATA=1

# --- Firebase / Firestore credentials (used when backend=firestore) ----------
FIREBASE_PROJECT_ID=
# Path is resolved from the directory you run uvicorn in (the repo root).
FIREBASE_SERVICE_ACCOUNT_FILE=./firebase-service-account.json
# Or paste the whole JSON inline instead of a file:
# FIREBASE_SERVICE_ACCOUNT_JSON=
# Local persistence without a service account:
# FIRESTORE_EMULATOR_HOST=127.0.0.1:8080

# --- Google Drive (stores the original uploaded PDFs) ------------------------
# 1. Create a Google Cloud service account + JSON key (see README / setup notes).
# 2. Create a Drive folder, copy its ID from the URL, and SHARE that folder
#    with the service account's client_email (Editor).
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_DRIVE_SERVICE_ACCOUNT_FILE=./google-drive-service-account.json
# Or inline JSON instead of a file:
# GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON=

# --- Frontend config ---------------------------------------------------------
# Vite reads these from frontend/.env.local, NOT this file. Listed for reference.
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_APP_ID=
